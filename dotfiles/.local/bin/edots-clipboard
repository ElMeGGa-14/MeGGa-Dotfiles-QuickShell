#!/usr/bin/env bash

set -euo pipefail

if ! command -v cliphist >/dev/null 2>&1 || ! command -v fuzzel >/dev/null 2>&1; then
  notify-send "Clipboard" "Instala cliphist y fuzzel" -a edots || true
  exit 1
fi

selection="$(cliphist list | fuzzel --dmenu --prompt 'Clipboard > ' || true)"
[[ -n "$selection" ]] || exit 0
printf '%s' "$selection" | cliphist decode | wl-copy
