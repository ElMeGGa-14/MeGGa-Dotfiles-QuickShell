#!/usr/bin/env bash

set -euo pipefail

wall="${1:-$HOME/.local/share/edots/wallpapers/harbor.png}"
[[ -f "$wall" ]] || {
  printf 'No existe: %s\n' "$wall" >&2
  exit 1
}

hyprctl hyprpaper preload "$wall" >/dev/null 2>&1 || true
hyprctl hyprpaper wallpaper ",$wall" >/dev/null 2>&1 || true
notify-send "Wallpaper" "$wall" -a edots || true
